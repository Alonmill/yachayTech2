@model IEnumerable<YachayTech_p_cov.Models.ResultadoEvaluacion>

@{
    ViewData["Title"] = "Panel de Control";
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card voc-card">
            <div class="voc-card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <p class="voc-eyebrow mb-2">Panel administrativo</p>
                    <h2 class="h3 mb-1">Seguimiento de evaluaciones</h2>
                    <p class="text-muted mb-0">Visualiza resultados y perfiles detectados en tiempo real.</p>
                </div>
                <span class="badge rounded-pill text-bg-dark px-3 py-2">Administrador</span>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 admin-table">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Fecha y hora</th>
                                <th>Postulante</th>
                                <th>Correo institucional</th>
                                <th class="text-center">Puntaje</th>
                                <th>Perfil detectado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">No hay evaluaciones registradas aún.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted small">@item.FechaPrueba.ToString("dd/MMM/yyyy HH:mm")</td>
                                        <td class="fw-semibold">@item.Usuario.Nombre @item.Usuario.Apellido</td>
                                        <td><a href="mailto:@item.Usuario.Correo" class="text-decoration-none">@item.Usuario.Correo</a></td>
                                        <td class="text-center"><span class="badge bg-dark rounded-pill fs-6">@item.PuntajeTotal pts</span></td>
                                        <td>
                                            @{
                                                var colorBadge = item.CategoriaAsignada.Contains("Especialista") ? "bg-success" :
                                                item.CategoriaAsignada.Contains("Innovador") ? "bg-info text-dark" :
                                                "bg-warning text-dark";
                                            }
                                            <span class="badge @colorBadge p-2">@item.CategoriaAsignada</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>