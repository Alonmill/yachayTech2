@model YachayTech_p_cov.ViewModel.LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">
        <div class="card voc-card">
            <div class="voc-card-header">
                <p class="voc-eyebrow mb-2">Acceso seguro</p>
                <h2 class="h3 mb-2">Iniciar sesión</h2>
                <p class="text-muted mb-0">Ingresa con tu cuenta para continuar tu test vocacional.</p>
            </div>
            <div class="card-body p-4 p-lg-5">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <form asp-action="Login" method="post" class="row g-3">
                    <div class="col-12">
                        <label asp-for="Correo" class="form-label"></label>
                        <input asp-for="Correo" class="form-control form-control-lg" />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Password" class="form-label">Contraseña</label>
                        <input asp-for="Password" class="form-control form-control-lg" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-12 d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Entrar</button>
                        <a asp-controller="Registro" asp-action="Index" class="btn btn-outline-dark">Crear cuenta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}