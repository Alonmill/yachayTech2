@{
    ViewData["Title"] = "Resultado del Test";
    var puntaje = (int?)ViewBag.PuntajeTotal ?? 0;
    var perfil = puntaje >= 12 ? "Especialista (Desarrollo/IA)" : puntaje >= 8 ? "Innovador (I+D)" : "Explorador Tecnológico";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-6">
        <div class="card voc-card text-center">
            <div class="voc-card-header text-start">
                <p class="voc-eyebrow mb-2">Reporte final</p>
                <h2 class="h3 mb-1">Evaluación completada</h2>
                <p class="text-muted mb-0">Este resultado refleja tus preferencias y afinidad inicial con áreas tecnológicas.</p>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div class="metric-box p-4 mb-4">
                    <p class="mb-1 text-uppercase fw-semibold text-muted small">Puntaje total</p>
                    <h1 class="display-3 fw-bold text-primary mb-1">@puntaje</h1>
                    <p class="mb-0 text-muted">Perfil sugerido: <strong>@perfil</strong></p>
                </div>

                <p class="text-muted mb-4">Recomendación: conversa este resultado con un orientador para definir tu ruta formativa y próximos pasos.</p>

                <div class="d-grid gap-2">
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary btn-lg">Realizar nuevamente</a>
                </div>
            </div>
        </div>
    </div>
</div>
