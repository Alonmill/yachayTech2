@model YachayTech_p_cov.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "Registro de Participante";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8 col-xl-7">
        <div class="card voc-card">
            <div class="voc-card-header">
                <p class="voc-eyebrow mb-2">Inicio de evaluación</p>
                <h2 class="h3 mb-2">Registro para test vocacional profesional</h2>
                <p class="text-muted mb-0">Crea tu cuenta segura para iniciar una experiencia guiada de orientación tecnológica.</p>
            </div>


            <div class="card-body p-4 p-lg-5">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <form asp-action="Index" method="post" class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label text-muted"></label>
                        <input asp-for="Nombre" class="form-control form-control-lg" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido" class="form-label text-muted"></label>
                        <input asp-for="Apellido" class="form-control form-control-lg" />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Correo" class="form-label text-muted">Correo institucional</label>
                        <input asp-for="Correo" class="form-control form-control-lg" placeholder="usuario@cibertec.edu.pe" />
                        <span asp-validation-for="Correo" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label text-muted">Contraseña</label>
                        <input asp-for="Password" class="form-control form-control-lg" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label text-muted">Confirmar contraseña</label>
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="col-12 d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg">Crear cuenta y comenzar evaluación</button>
                        <a asp-controller="Cuenta" asp-action="Login" class="btn btn-outline-dark">Ya tengo cuenta</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}